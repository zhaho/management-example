{
  "apiVersion": "v1",
  "kind": "ResourceQuota",
  "metadata": {
    "name": "team-finance-quota",
    "namespace": "team-finance",
    "labels": {
      "team": "team-finance",
      "environment": "staging"
    }
  },
  "spec": {
    "hard": {
      "requests.cpu": "250m",
      "limits.cpu": 2,
      "requests.memory": "256Mi",
      "limits.memory": "2Gi",
      "pods": "20"
    }
  }
}
