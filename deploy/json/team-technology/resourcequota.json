  "apiVersion": "v1",
  "kind": "ResourceQuota",
  "metadata": {
    "name": "team-technology-quota",
    "namespace": "team-technology",
    "labels": {
      "team": "team-technology",
      "environment": "production"
    }
  },
  "spec": {
    "hard": {
      "requests.cpu": "500m",
